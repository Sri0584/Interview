{
    "include": [
        "./src/**/*"
    ],
    "compilerOptions": {
        "target": "ES2021",
        "module": "ESNext",
        "jsx": "react-jsx",
        "lib": ["DOM", "ES2021"],
        "strict": true,
        "moduleResolution": "node",
        "allowSyntheticDefaultImports": true,
        "esModuleInterop": true
    }
}